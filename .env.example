# Copy this file to ".env" and fill in real values. ".env" is gitignored.
# Vite only exposes variables prefixed with VITE_ to the app at build time.
# Run locally with:  npm run dev
# In CI, these come from GitHub repo Secrets (see .github/workflows/deploy.yml).

# Starting access password for the Manager Studio (changeable in-app later).
VITE_MANAGER_PASSWORD=honeybee

# Firebase web config (Project settings > Your apps > Web app).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_STORAGE_BUCKET=
