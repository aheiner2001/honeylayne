# Copy this file to ".env" and fill in real values. ".env" is gitignored.
# Build/run locally with:  flutter run -d chrome --dart-define-from-file=.env
# In CI, these come from GitHub repo Secrets (see .github/workflows/deploy.yml).

# Fallback password (only used if Firebase isn't configured).
MANAGER_PASSWORD=changeme

# Comma-separated Google account emails allowed into the Manager Studio.
# Leave empty to allow any signed-in Google account (not recommended).
MANAGER_EMAILS=

# Firebase web config (Project settings > Your apps > Web app).
FIREBASE_API_KEY=
FIREBASE_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_PROJECT_ID=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
