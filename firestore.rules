rules_version = '2';

// Honey Layne: anyone can read the catalog + site settings; writes are open
// (the manager page is gated by a client-side password). Fine for a small
// shop. To lock down later, add Firebase Auth and require request.auth != null.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read: if true;
      allow write: if true;
    }
  }
}
