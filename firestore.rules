rules_version = '2';

// Honey Layne: anyone can read the catalog + site settings; only a signed-in
// manager (Firebase Auth) can write.
service cloud.firestore {
  match /databases/{database}/documents {
    // Public catalog + site settings: anyone can read, manager can write.
    match /products/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /site/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Orders hold customer contact + shipping details. Only Cloud Functions
    // (Admin SDK, which bypasses these rules) may touch them.
    match /orders/{id} {
      allow read, write: if false;
    }
  }
}
